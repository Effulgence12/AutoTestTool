# Qwen/DashScope LLM provider
# One shared key is enough for all agents in this course project.
# Keep real keys in .env or shell environment only; never commit them.
ENABLE_LLM=1
QWEN_API_KEY=
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3.5-plus-2026-04-20
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192
LLM_TIMEOUT_SECONDS=180
QWEN_ENABLE_THINKING=0
